<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Graduation Form</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-5">
    <h2>Graduation Registration</h2>
    <form id="userForm">
      <input type="hidden" id="student_id" value="<%= student.student_id %>">

      <div class="mb-3">
        <label>First Name</label>
        <input class="form-control" id="firstname" value="<%= student.first_name %>" readonly>
      </div>
      <div class="mb-3">
        <label>Middle Name</label>
        <input class="form-control" id="middlename" value="<%= student.mid_name || '' %>">
      </div>
      <div class="mb-3">
        <label>Last Name</label>
        <input class="form-control" id="lastname" value="<%= student.last_name %>" readonly>
      </div>
      <div class="mb-3">
        <label>Course</label>
        <input class="form-control" id="course" value="<%= student.course_name %>" readonly>
      </div>
      <div class="mb-3">
        <label>Faculty</label>
        <input class="form-control" id="faculty" value="<%= student.faculty || '' %>">
      </div>
      <div class="mb-3">
        <label>Gender</label><br>
        <input type="radio" name="gender" value="Male" <%= student.gender === 'Male' ? 'checked' : '' %>> Male
        <input type="radio" name="gender" value="Female" <%= student.gender === 'Female' ? 'checked' : '' %>> Female
        <input type="radio" name="gender" value="Other" <%= student.gender === 'Other' ? 'checked' : '' %>> Other
      </div>
      <div class="mb-3">
        <label>Attending</label>
        <select id="attending" class="form-control">
          <option value="Yes" <%= student.attending === 'Yes' ? 'selected' : '' %>>Yes</option>
          <option value="No" <%= student.attending === 'No' ? 'selected' : '' %>>No</option>
        </select>
      </div>
      <div class="mb-3">
        <label>Guests</label>
        <input class="form-control" type="number" id="guests" value="<%= student.guest_count || 0 %>">
      </div>
      <div class="mb-3">
        <label>Food Preference</label>
        <input class="form-control" id="food" value="<%= student.food_pref || '' %>">
      </div>
      <div class="mb-3">
        <label>Submission Time</label>
        <input class="form-control" type="datetime-local" id="submission_time">
      </div>
      <button class="btn btn-primary w-100">Submit</button>
    </form>
    <div id="message" class="mt-3"></div>
  </div>

  <script src="/js/script.js"></script>
</body>
</html>
